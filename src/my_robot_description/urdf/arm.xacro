<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Properties -->
  <xacro:property name="arm_base_length" value="0.1"/>
  <xacro:property name="arm_base_width"  value="0.1"/>
  <xacro:property name="arm_base_height" value="0.02"/>

  <xacro:property name="arm1_radius" value="0.02"/>
  <xacro:property name="arm1_length" value="0.3"/>

  <xacro:property name="arm2_radius" value="0.02"/>
  <xacro:property name="arm2_length" value="0.3"/>

  <!-- World -->
  <link name="world"/>

  <!-- Base -->
  <link name="arm_base_link">
    <visual>
      <geometry>
        <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
      </geometry>
      <origin xyz="0 0 ${arm_base_height/2}"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <box size="${arm_base_length} ${arm_base_width} ${arm_base_height}"/>
      </geometry>
      <origin xyz="0 0 ${arm_base_height/2}"/>
    </collision>
  </link>

  <!-- Arm1 -->
  <link name="arm1_link">
    <visual>
      <geometry>
        <cylinder radius="${arm1_radius}" length="${arm1_length}"/>
      </geometry>
      <origin xyz="0 0 ${arm1_length/2}"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${arm1_radius}" length="${arm1_length}"/>
      </geometry>
      <origin xyz="0 0 ${arm1_length/2}"/>
    </collision>
  </link>

  <!-- Arm2 -->
  <link name="arm2_link">
    <visual>
      <geometry>
        <cylinder radius="${arm2_radius}" length="${arm2_length}"/>
      </geometry>
      <origin xyz="0 0 ${arm2_length/2}"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${arm2_radius}" length="${arm2_length}"/>
      </geometry>
      <origin xyz="0 0 ${arm2_length/2}"/>
    </collision>
  </link>

  <!-- End Effector -->
  <link name="ee_link"/>

  <!-- Joints -->
  <joint name="base_yaw_joint" type="revolute">
    <parent link="world"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 ${arm_base_height/2}"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="2"/>
  </joint>

  <joint name="arm_joint1" type="revolute">
    <parent link="arm_base_link"/>
    <child link="arm1_link"/>
    <origin xyz="0 0 ${arm_base_height}"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="50" velocity="2"/>
  </joint>

  <joint name="arm_joint2" type="revolute">
    <parent link="arm1_link"/>
    <child link="arm2_link"/>
    <origin xyz="0 0 ${arm1_length}"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5" upper="1.5" effort="50" velocity="2"/>
  </joint>

  <joint name="ee_joint" type="fixed">
    <parent link="arm2_link"/>
    <child link="ee_link"/>
    <origin xyz="0 0 ${arm2_length}"/>
  </joint>

</robot>